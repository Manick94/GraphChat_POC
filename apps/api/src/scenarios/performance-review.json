      "description": "Employee trust in manager (0-10)"
    },
    {
      "name": "defensiveness_level",
      "type": "number",
      "default": 4,
      "description": "Employee defensiveness (0-10)"
    },
    {
      "name": "commitment_level",
      "type": "number",
      "default": 5,
      "description": "Employee commitment to improve (0-10)"
    },
    {
      "name": "psychological_safety",
      "type": "string",
      "default": "medium",
      "description": "Level of psychological safety: low, medium, high"
    }
  ],
  "scoring": {
    "empathy": {
      "weight": 25,
      "description": "Showed genuine empathy and understanding"
    },
