      "default": 3,
      "description": "Customer trust in agent (0-10)"
    },
    {
      "name": "churn_risk",
      "type": "string",
      "default": "high",
      "description": "Risk of customer leaving: low, medium, high"
    },
    {
      "name": "empathy_shown",
      "type": "boolean",
      "default": false,
      "description": "Whether agent showed empathy"
    },
    {
      "name": "solution_offered",
